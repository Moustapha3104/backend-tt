{
  "name": "tontine-nataal",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon --watch server.js --watch prisma server.js",
    "dev:client": "npm run dev --prefix tontine-front",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --prefix tontine-front",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tontine-front/"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2"
  }
}
